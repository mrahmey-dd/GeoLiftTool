# GeoLift Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Security (REQUIRED — change before any deployment) ────────────
JWT_SECRET=replace_this_with_a_long_random_string_min_32_chars

# ── Database ──────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=geolift
DB_USER=geolift
DB_PASSWORD=geolift_dev

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Object Storage (MinIO / S3) ────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=geolift-data
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev

# For AWS S3 in production, remove S3_ENDPOINT and set:
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1

# ── Frontend ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Application ───────────────────────────────────────────────────
GEOLIFT_ENV=development
LOG_LEVEL=INFO
PORT=8000

# ── Worker ────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── CORS (comma-separated allowed origins) ────────────────────────
CORS_ORIGIN=http://localhost:5173
